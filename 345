#define _CRT_SECURE_NO_WARNINGS
#include <iostream>
#include <filesystem>
#include <vector>
#include <iomanip>
#include <string>
#include <algorithm>
#include <chrono>
#include <fstream>

namespace fs = std::filesystem;

#ifdef _WIN32
#include <windows.h>
#endif

struct FolderData {
    std::string path;
    uintmax_t file_count;   // общее количество файлов во всей папке (рекурсивно)
    uintmax_t size;         // общий размер всех файлов в папке (рекурсивно)
};

class DirectoryAnalyzer {
private:
    std::vector<FolderData> folders;

    std::string get_size_string(uintmax_t size_bytes) {
        const char* units[] = { "B", "KB", "MB", "GB", "TB", "PB" };
        double size = static_cast<double>(size_bytes);
        int unit_idx = 0;
        while (size >= 1024.0 && unit_idx < 5) {
            size /= 1024.0;
            unit_idx++;
        }
        char buffer[32];
#ifdef _MSC_VER
        sprintf_s(buffer, sizeof(buffer), "%.1f %s", size, units[unit_idx]);
#else
        sprintf(buffer, "%.1f %s", size, units[unit_idx]);
#endif
        return std::string(buffer);
    }

    // Подсчёт количества файлов в папке (рекурсивно)
    uintmax_t count_files_in_folder(const fs::path& folder_path) {
        uintmax_t count = 0;
        try {
            for (const auto& entry : fs::recursive_directory_iterator(
                folder_path, fs::directory_options::skip_permission_denied)) {
                if (fs::is_regular_file(entry)) {
                    count++;
                }
            }
        }
        catch (const std::exception&) {
            // игнорируем ошибки доступа
        }
        return count;
    }

    // Подсчёт общего размера папки (рекурсивно)
    uintmax_t calculate_folder_size(const fs::path& folder_path) {
        uintmax_t total = 0;
        try {
            for (const auto& entry : fs::recursive_directory_iterator(
                folder_path, fs::directory_options::skip_permission_denied)) {
                if (fs::is_regular_file(entry)) {
                    total += fs::file_size(entry);
                }
            }
        }
        catch (const std::exception&) {
            // игнорируем ошибки доступа
        }
        return total;
    }

    void collect_folders(const fs::path& current_path) {
        try {
            if (!fs::is_directory(current_path)) return;

            // Получаем данные для текущей папки
            uintmax_t file_cnt = count_files_in_folder(current_path);
            uintmax_t total_size = calculate_folder_size(current_path);

            folders.push_back({ current_path.string(), file_cnt, total_size });

            // Обрабатываем подпапки
            std::vector<fs::path> subdirs;
            for (const auto& entry : fs::directory_iterator(current_path)) {
                if (fs::is_directory(entry)) {
                    subdirs.push_back(entry.path());
                }
            }
            std::sort(subdirs.begin(), subdirs.end());
            for (const auto& sub : subdirs) {
                collect_folders(sub);
            }
        }
        catch (const std::exception&) {
            // игнорируем ошибки
        }
    }

public:
    void analyze(const fs::path& root) {
        std::cout << "Сканирование папок: " << root << std::endl;
        auto start = std::chrono::high_resolution_clock::now();

        folders.clear();
        collect_folders(root);

        auto end = std::chrono::high_resolution_clock::now();
        auto ms = std::chrono::duration_cast<std::chrono::milliseconds>(end - start).count();
        std::cout << "Найдено папок: " << folders.size() << " за " << ms << " ms\n";
    }

    void save_to_file(const std::string& filename) {
        if (folders.empty()) {
            std::cerr << "Нет данных для сохранения.\n";
            return;
        }

        // Вычисляем максимальную ширину для каждого столбца
        size_t max_path_len = 4;   // минимум для заголовка "Путь"
        size_t max_files_len = 10; // "Файлов"
        size_t max_size_len = 6;   // "Размер"

        for (const auto& f : folders) {
            max_path_len = std::max(max_path_len, f.path.length());
            std::string file_str = std::to_string(f.file_count);
            max_files_len = std::max(max_files_len, file_str.length());
            std::string size_str = get_size_string(f.size);
            max_size_len = std::max(max_size_len, size_str.length());
        }

        // Ширина с отступами по 2 пробела с каждой стороны
        const int padding = 2;
        int col1_width = static_cast<int>(max_path_len) + padding * 2;
        int col2_width = static_cast<int>(max_files_len) + padding * 2;
        int col3_width = static_cast<int>(max_size_len) + padding * 2;

        // Функция для создания горизонтальной линии
        auto make_line = [&](char left, char mid, char right, char fill) {
            std::string line;
            line += left;
            line += std::string(col1_width, fill);
            line += mid;
            line += std::string(col2_width, fill);
            line += mid;
            line += std::string(col3_width, fill);
            line += right;
            return line;
        };

        std::ofstream out(filename);
        if (!out) {
            std::cerr << "Не удалось открыть файл: " << filename << std::endl;
            return;
        }

        // Заголовок
        out << make_line('┌', '┬', '┐', '─') << "\n";
        out << "│ " << std::left << std::setw(col1_width - 2) << "Путь"
            << "│ " << std::setw(col2_width - 2) << "Количество файлов"
            << "│ " << std::setw(col3_width - 2) << "Размер"
            << "│\n";
        out << make_line('├', '┼', '┤', '─') << "\n";

        // Данные
        for (const auto& f : folders) {
            out << "│ " << std::left << std::setw(col1_width - 2) << f.path
                << "│ " << std::right << std::setw(col2_width - 2) << f.file_count
                << "│ " << std::right << std::setw(col3_width - 2) << get_size_string(f.size)
                << "│\n";
        }

        // Итоговая линия
        out << make_line('└', '┴', '┘', '─') << "\n";

        // Дополнительная статистика
        uintmax_t total_files = 0;
        uintmax_t total_size = 0;
        for (const auto& f : folders) {
            total_files += f.file_count;
            total_size += f.size;
        }
        out << "\nВсего папок: " << folders.size() << "\n";
        out << "Всего файлов: " << total_files << "\n";
        out << "Общий размер: " << get_size_string(total_size) << "\n";

        out.close();
        std::cout << "Результат сохранён в файл: " << filename << std::endl;
    }
};

int main(int argc, char* argv[]) {
#ifdef _WIN32
    setlocale(LC_ALL, "Russian");
    SetConsoleCP(65001);
    SetConsoleOutputCP(65001);
#endif

    std::cout << "Анализатор папок (только папки) с выводом в файл\n";
    std::cout << "================================================\n";

    fs::path target_path;
    if (argc > 1) {
        target_path = argv[1];
    }
    else {
        std::cout << "Введите путь к папке для анализа (Enter = текущая): ";
        std::string input;
        std::getline(std::cin, input);
        target_path = input.empty() ? fs::current_path() : input;
    }

    if (!fs::exists(target_path) || !fs::is_directory(target_path)) {
        std::cerr << "Ошибка: папка не существует или не является директорией.\n";
        return 1;
    }

    DirectoryAnalyzer analyzer;
    analyzer.analyze(target_path);

    std::cout << "Введите имя выходного файла (можно с путём): ";
    std::string out_filename;
    std::getline(std::cin, out_filename);
    if (out_filename.empty()) {
        out_filename = "report.txt";
    }

    analyzer.save_to_file(out_filename);

    std::cout << "Готово. Нажмите Enter для выхода...";
    std::cin.get();
    return 0;
}